    },
    {
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 14 },
      "id": 5,
      "fieldConfig": { "defaults": { "unit": "pps" } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rate(ifInErrors{job=\"snmp\",ifName=~\"eth[1-6]\"}[1m]) + rate(ifInDiscards{job=\"snmp\",ifName=~\"eth[1-6]\"}[1m])",
          "legendFormat": "{{instance}} {{ifName}}"
        }
      ],
      "title": "RX Errors + Discards — all links (disruption indicator)",
      "type": "timeseries"
    },
    {
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 14 },
      "id": 6,
      "description": "deriv of ifOutDiscards — rising = TX queue overflowing (congestion). IF-MIB has no queue-depth counter; discard rate growth is the observable proxy.",
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "deriv(ifOutDiscards{job=\"snmp\",ifName=~\"eth[1-6]\"}[30s])",
          "legendFormat": "{{instance}} {{ifName}}"
        }
      ],
      "title": "TX Discard Trend — all links (rising = congestion building)",
      "type": "timeseries"
    }
